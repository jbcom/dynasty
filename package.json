{
  "name": "dynasty",
  "private": true,
  "version": "0.38.0",
  "type": "module",
  "description": "A dynastic-saga life-simulator: play the rise of a dynasty from immigrant origins to the stars.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:browser": "vitest run --project browser",
    "test:all": "vitest run",
    "test:e2e": "playwright test",
    "timeline:dump": "vite-node scripts/timeline-dump.ts --",
    "timeline:sweep": "vite-node scripts/timeline-dump.ts sweep --",
    "cartoonify": "node scripts/cartoonify.mjs",
    "cap:sync": "cap sync",
    "cap:run:android": "cap run android",
    "genai:expand": "vite-node scripts/genai-expand.ts --",
    "genai:qa": "vite-node scripts/genai-qa.ts --"
  },
  "dependencies": {
    "@capacitor/device": "^8.0.2",
    "d3-force": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "howler": "^2.2.4",
    "koota": "^0.6.6",
    "motion": "^12.40.0",
    "open-props": "^1.7.23",
    "seedrandom": "^3.0.5",
    "svelte": "^5.56.3",
    "tone": "^15.1.22",
    "uplot": "^1.6.32",
    "yuka": "0.7.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@google/genai": "^2.9.0",
    "@playwright/test": "^1.61.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/d3-force": "^3.0.10",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/howler": "^2.2.13",
    "@types/node": "^26.0.0",
    "@types/seedrandom": "^3.0.8",
    "@types/yuka": "0.7.4",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "jimp": "^1.6.1",
    "playwright": "^1.61.0",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  }
}
