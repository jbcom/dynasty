*.jks

# Raw source photos — only cartoon derivatives (our own work) are shipped.
public/assets/photos/

# agent-state gitignored cache (re-derivable)
.agent-state/digest.md
.agent-state/cursor.md
.agent-state/.indexed-sha
.agent-state/.last-stop-sha
.agent-state/.last-compaction
.agent-state/batch.json

# .claude runtime artifacts (locks, scheduled tasks, stray legacy skill cache).
# gates.json and other tracked config stay in git.
.claude/state/
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json

# Visual-test screenshots are LOCAL-ONLY review artifacts — vitest writes them via
# page.screenshot() purely so the rendering can be eyeballed; nothing asserts against
# them (no toMatchSnapshot baseline), so tracking them is pure non-deterministic churn.
**/__screenshots__/

# itch downloader (local only)
.env
.itch-cache/
raw-assets/
